@model IEnumerable<JDSExpertClone.Models.Product>

<!-- Hero Section with JDS Logo -->
<div class="row align-items-center bg-white p-4 rounded-4 shadow-sm border-start border-danger border-5 mb-5">
    <div class="col-md-7">
        <h1 class="display-4 fw-bold">Freshly Brewed <br /><span style="color:#E11A22;">Everyday!</span></h1>
        <p class="lead text-muted">Quality Coffee, Juices, and Cookies at your doorstep.</p>
        <form method="get" class="d-flex w-75 mt-4">
            <input name="search" class="form-control p-3 border-dark rounded-start-pill" placeholder="Search for espresso, mango..." />
            <button class="btn btn-dark px-4 rounded-end-pill" type="submit">Search</button>
        </form>
    </div>
    <div class="col-md-5 text-center d-none d-md-block">
        <img src="~/images/logo.jpg" class="img-fluid rounded shadow" style="max-height: 280px;" />
    </div>
</div>

<h3 class="fw-bold mb-4">Our Popular Items</h3>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-lg-3 mb-4">
            <div class="card h-100 food-card p-2">
                <img src="@item.ImageUrl" class="card-img-top rounded-4" style="height: 180px; object-fit: cover;">
                <div class="card-body">
                    <span class="badge bg-danger mb-2">@item.Category.Name</span>
                    <h5 class="fw-bold mb-1 text-truncate">@item.Name</h5>
                    <p class="text-muted small">@item.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="h5 fw-bold mb-0">৳@item.Price</span>
                        <button class="btn btn-jds btn-sm px-3 shadow-sm">+ Add</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>