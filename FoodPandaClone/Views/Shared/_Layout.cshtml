<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JDS EXPERT - Best Food & Drinks</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        :root { --jds-red: #E11A22; --jds-black: #121212; }
        body { background-color: #f4f4f4; font-family: 'Segoe UI', sans-serif; }
        .navbar { border-bottom: 3px solid var(--jds-red); background: #fff !important; }
        .navbar-brand { font-weight: 900; color: var(--jds-red) !important; }
        .btn-jds { background-color: var(--jds-red); color: white; font-weight: bold; border-radius: 8px; }
        .btn-jds:hover { background-color: black; color: white; }
        .food-card { border: none; border-radius: 15px; background: white; transition: 0.4s; }
        .food-card:hover { transform: translateY(-8px); box-shadow: 0 12px 25px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top shadow-sm py-2">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="~/images/logo.jpg" style="height: 55px;" />
                <span class="ms-2">JDS EXPERT</span>
            </a>
            <div class="d-flex align-items-center ms-auto">
                <a class="nav-link me-3 fw-bold text-dark" href="/Products">Admin</a>
                <a href="#" class="position-relative me-3">
                    <i class="bi bi-cart4 fs-3 text-dark"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
                </a>
                <button class="btn btn-jds px-4">Login</button>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">© 2024 JDS EXPERT | Quality Food & Beverages</p>
        </div>
    </footer>
</body>
</html>